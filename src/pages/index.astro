---
---

<section class="page">
  <header class="site-header">
    <a href="/" class="site-brand">Yoga Loving</a>

    <nav class="site-nav">
      <a href="#approach">Approach</a>
      <a href="#practice">Practice</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
      <a href="#practice" class="nav-link-quiet">Begin</a>
    </nav>
  </header>

  <section class="hero">
    <video autoplay muted loop playsinline class="bg-video">
      <source src="/video.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="logo-wrap">
      <img src="/logo.png" alt="Yoga Loving logo" />
    </div>

    <div class="content">
      <h1 class="hero-title">Yoga Loving</h1>
      <p class="trio">Calm • Balance • Ease</p>
      <a href="#practice" class="hero-link">Enter the Practice</a>
    </div>
  </section>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

html, body {
  margin: 0;
  padding: 0;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: #ece8df;
  color: #3a2d25;
}

.page {
  min-height: 100vh;
  background: #ece8df;
}

.site-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26px 34px;
  z-index: 5;
  background: transparent;
}

.site-brand {
  font-size: 1rem;
  font-weight: 500;
  color: #3a2d25;
  text-decoration: none;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 28px;
}

.site-nav a {
  font-size: 0.95rem;
  font-weight: 400;
  color: rgba(58, 45, 37, 0.82);
  text-decoration: none;
}

.nav-link-quiet {
  border-bottom: 1px solid rgba(58, 45, 37, 0.35);
  padding-bottom: 2px;
}

.hero {
  position: relative;
  min-height: 100vh;
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.overlay {
  position: absolute;
  inset: 0;
  background: rgba(28, 20, 14, 0.06);
  z-index: 1;
}

.logo-wrap {
  position: absolute;
  top: 140px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}

.logo-wrap img {
  width: 360px;
  height: 360px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
}

.content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 560px 24px 80px;
  text-align: center;
}

.hero-title {
  margin: 0;
  font-size: 4.2rem;
  line-height: 0.98;
  font-weight: 400;
  letter-spacing: -0.04em;
  color: #3a2d25;
}

.trio {
  margin: 14px 0 0;
  font-size: 1rem;
  font-weight: 400;
  color: rgba(58, 45, 37, 0.72);
}

.hero-link {
  display: inline-block;
  margin-top: 18px;
  text-decoration: none;
  font-size: 1rem;
  font-weight: 500;
  color: #3a2d25;
  border-bottom: 1px solid rgba(58, 45, 37, 0.42);
  padding-bottom: 4px;
}

@media (max-width: 1100px) {
  .logo-wrap {
    top: 120px;
  }

  .logo-wrap img {
    width: 280px;
    height: 280px;
  }

  .content {
    padding-top: 470px;
  }

  .hero-title {
    font-size: 3.6rem;
  }
}

@media (max-width: 760px) {
  .site-header {
    flex-direction: column;
    gap: 12px;
    padding: 16px 14px;
  }

  .site-nav {
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 16px;
  }

  .logo-wrap {
    top: 130px;
  }

  .logo-wrap img {
    width: 220px;
    height: 220px;
  }

  .content {
    padding-top: 410px;
    padding-left: 18px;
    padding-right: 18px;
  }

  .hero-title {
    font-size: 2.9rem;
  }

  .trio,
  .hero-link {
    font-size: 0.95rem;
  }
}
</style>
