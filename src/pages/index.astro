<section class="page">
  <header class="site-header">
    <a href="/" class="site-brand">Yoga Loving</a>

    <nav class="site-nav">
      <a href="#approach">Approach</a>
      <a href="#practice">Practice</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
      <a href="#practice" class="nav-link-quiet">Begin</a>
    </nav>
  </header>

  <section class="hero">
    <video autoplay muted loop playsinline class="bg-video">
      <source src="/video.mp4" type="video/mp4" />
    </video>

    <div class="overlay"></div>

    <div class="logo-wrap">
      <img src="/logo.png" alt="Yoga Loving logo" />
    </div>

    <div class="content">
      <h1 class="hero-title">Yoga Loving</h1>
      <p class="trio">Calm • Balance • Ease</p>
      <a href="#practice" class="hero-link">Enter the Practice</a>
    </div>
  </section>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');

html, body {
  margin: 0;
  padding: 0;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: #ece8df;
  color: #3a2d25;
}

.page {
  min-height: 100vh;
  background: #ece8df;
}

.site-header {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34px 34px;
  z-index: 5;
  background: transparent;
}

.site-brand {
  font-size: 1rem;
  font-weight: 500;
  color: #3a2d25;
  text-decoration: none;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 28px;
}

.site-nav a {
  font-size: 0.95rem;
  font-weight: 400;
  color: rgba(58, 45, 37, 0.82);
  text-decoration: none;
}

.nav-link-quiet {
  border-bottom: 1px solid rgba(58, 45, 37, 0.35);
  padding-bottom: 2px;
}

.hero {
  position: relative;
  min-height: 100vh;
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.overlay {
  position: absolute;
  inset: 0;
  background: rgba(28, 20, 14, 0.16);
  z-index: 1;
}

.logo-wrap {
  position: absolute;
  top: 90px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}

.logo-wrap img {
  width: 290px;
  height: 290px;
  border-radius: 50%;
  object-fit: cover;
  box-shadow: 0 10px 26px rgba(0, 0, 0, 0.14);
}

.content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
padding: 190px 24px 60px;
  text-align: center;
}

.hero-title {
  margin: -10px 0 0;
  font-size: 4.5rem;
  line-height: 0.92;
  font-weight: 400;
  letter-spacing: -0.05em;
  color: #241b16;
text-shadow: 0 2px 10px rgba(255, 248, 236, 0.12);
}

.trio {
  margin-top: 8px;
  font-size: 1.35rem;
  font-weight: 400;
  letter-spacing: 0.035em;
  color: rgba(36, 27, 22, 0.8);
}

.hero-link {
  display: inline-block;
  margin-top: 14px;
  text-decoration: none;
  font-size: 1.1rem;
  font-weight: 500;
  color: #2a211b;
  border-bottom: 1px solid rgba(42, 33, 27, 0.65);
  padding-bottom: 3px;
}

@media (max-width: 1100px) {
  .logo-wrap {
    top: 120px;
  }

  .logo-wrap img {
    width: 280px;
    height: 280px;
  }

  .content {
    padding-top: 390px;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
  }

  .trio {
    font-size: 1.2rem;
  }
}

@media (max-width: 760px) {
  .site-header {
    flex-direction: column;
    gap: 12px;
    padding: 16px 14px;
  }

  .site-nav {
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 16px;
  }

  .logo-wrap {
    top: 130px;
  }

  .logo-wrap img {
    width: 220px;
    height: 220px;
  }

  .content {
    padding-top: 340px;
    padding-left: 18px;
    padding-right: 18px;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
  }

  .trio {
    font-size: 1.3rem;
  }

  .hero-link {
    font-size: 1.05rem;
  }
}
</style>
